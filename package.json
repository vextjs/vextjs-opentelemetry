{
  "name": "vextjs-opentelemetry",
  "version": "0.1.5",
  "description": "Official OpenTelemetry plugin for VextJS — zero-config traces, metrics and log correlation",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "vext": {
    "preload": "./dist/instrumentation.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./instrumentation": {
      "types": "./dist/instrumentation.d.ts",
      "import": "./dist/instrumentation.js"
    },
    "./express": {
      "types": "./dist/adapters/express.d.ts",
      "import": "./dist/adapters/express.js",
      "require": "./dist/adapters/express.cjs"
    },
    "./koa": {
      "types": "./dist/adapters/koa.d.ts",
      "import": "./dist/adapters/koa.js",
      "require": "./dist/adapters/koa.cjs"
    },
    "./hono": {
      "types": "./dist/adapters/hono.d.ts",
      "import": "./dist/adapters/hono.js",
      "require": "./dist/adapters/hono.cjs"
    },
    "./fastify": {
      "types": "./dist/adapters/fastify.d.ts",
      "import": "./dist/adapters/fastify.js",
      "require": "./dist/adapters/fastify.cjs"
    },
    "./vextjs": {
      "types": "./dist/adapters/vextjs.d.ts",
      "import": "./dist/adapters/vextjs.js",
      "require": "./dist/adapters/vextjs.cjs"
    },
    "./log": {
      "types": "./dist/log.d.ts",
      "import": "./dist/log.js",
      "require": "./dist/log.cjs"
    },
    "./init": {
      "types": "./dist/init.d.ts",
      "import": "./dist/init.js",
      "require": "./dist/init.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/build-cjs.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "peerDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.214.0",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.214.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/sdk-node": "^0.214.0",
    "express": ">=4.0.0",
    "fastify": ">=4.0.0",
    "hono": ">=4.0.0",
    "koa": ">=2.0.0",
    "vextjs": "^0.2.3"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api-logs": {
      "optional": true
    },
    "@opentelemetry/sdk-node": {
      "optional": true
    },
    "@opentelemetry/exporter-trace-otlp-http": {
      "optional": true
    },
    "@opentelemetry/exporter-metrics-otlp-http": {
      "optional": true
    },
    "@opentelemetry/auto-instrumentations-node": {
      "optional": true
    },
    "express": {
      "optional": true
    },
    "koa": {
      "optional": true
    },
    "hono": {
      "optional": true
    },
    "fastify": {
      "optional": true
    },
    "vextjs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.214.0",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/core": "^2.6.1",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.214.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/instrumentation": "^0.214.0",
    "@opentelemetry/otlp-transformer": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-logs": "^0.214.0",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@opentelemetry/sdk-trace-node": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.30.0",
    "@types/express": "^5.0.6",
    "@types/koa": "^3.0.2",
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.0",
    "express": "^5.2.1",
    "fastify": "^5.8.4",
    "hono": "^4.12.10",
    "koa": "^3.2.0",
    "prettier": "^3.8.1",
    "typescript": "^5.8.3",
    "vextjs": "file:../vext",
    "vitest": "^3.1.3"
  }
}